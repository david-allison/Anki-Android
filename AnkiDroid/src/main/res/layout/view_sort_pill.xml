<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:id="@+id/sort_pill_standard"
        android:layout_width="48dp"
        android:layout_height="32dp"
        android:background="@drawable/background_sort_pill_fill_start"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/sort_pill_standard_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:duplicateParentState="true"
            android:textColor="@color/sort_pill_content_color"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="A" />

        <ImageView
            android:id="@+id/sort_pill_standard_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="-2dp"
            android:duplicateParentState="true"
            android:importantForAccessibility="no"
            android:src="@drawable/outline_arrow_downward_alt_24"
            app:tint="@color/sort_pill_content_color"
            tools:ignore="ContentDescription" />
    </LinearLayout>

    <View
        android:layout_width="0.1dp"
        android:layout_height="32dp"
        android:alpha="0.1"
        android:background="?attr/colorOnSurface" />

    <LinearLayout
        android:id="@+id/sort_pill_reverse"
        android:layout_width="48dp"
        android:layout_height="32dp"
        android:background="@drawable/background_sort_pill_fill_end"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/sort_pill_reverse_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:duplicateParentState="true"
            android:textColor="@color/sort_pill_content_color"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="Z" />

        <ImageView
            android:id="@+id/sort_pill_reverse_arrow"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="-2dp"
            android:duplicateParentState="true"
            android:importantForAccessibility="no"
            android:src="@drawable/outline_arrow_downward_alt_24"
            app:tint="@color/sort_pill_content_color"
            tools:ignore="ContentDescription" />
    </LinearLayout>
</merge>
